ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

LLM_PROVIDER=anthropic   # anthropic | gemini | groq
LLM_MODEL=               # override del modelo; si vacío usa el default del proveedor
GEMINI_API_KEY=          # requerido si LLM_PROVIDER=gemini o como fallback de Groq
GEMINI_MODEL=            # modelo Gemini a usar; si vacío → gemini-2.0-flash-lite
GROQ_API_KEY=            # requerido si LLM_PROVIDER=groq
CCXT_EXCHANGE=binance
CCXT_TESTNET=true
CCXT_MARKET_TYPE=spot

# Local: DB_PATH=trading_brain.db
# Docker: DB_PATH=/app/data/trading_brain.db  (persiste en el volumen ./data)
DB_PATH=trading_brain.db

PAPER_INITIAL_BALANCE=10000
PAPER_RISK_PCT=0.01
PAPER_ATR_STOP_MULT=2.0
PAPER_MAX_HOLD_CANDLES=20

# Telegram (opcional — si no se configura, las notificaciones se silencian)
TELEGRAM_BOT_TOKEN=          # token del bot de ALERTAS salientes (@BotFather)
TELEGRAM_CHAT_ID=            # ID numérico del chat destino (@userinfobot)
TELEGRAM_COMMAND_BOT_TOKEN=  # token de un bot DEDICADO para comandos entrantes
                             # (/buffett). Debe ser distinto de TELEGRAM_BOT_TOKEN:
                             # dos procesos no pueden compartir getUpdates.

# ---------------------------------------------------------------------------
# Versionado de estrategias del scanner
#   v2 = screener de situaciones técnicas 1D (default, docs/estrategias_v2.md)
#   v1 = estrategias originales — rollback instantáneo sin tocar código
#        (snapshot de código también taggeado en git: `estrategias-v1`)
# ---------------------------------------------------------------------------
SCANNER_STRATEGY_SET=v2

# --- Set v2: screener de situaciones (todas activas por default) ---
SCANNER_V2_SITUACIONES=            # vacío = las 10; o subconjunto ej. "1,2,5,7"
SCANNER_V2_TOLERANCIA_EMA_PCT=0.5  # distancia máx. para considerar "toque" de EMA20
SCANNER_V2_ALEJADO_PCT=2           # distancia previa mínima para que un toque alerte
SCANNER_V2_RSI_SOBRECOMPRA=70
SCANNER_V2_RSI_SOBREVENTA=30
SCANNER_V2_TENDENCIA_PCT=8         # variación mínima en 20 ruedas (SIT 3/4)
SCANNER_V2_VOL_SPIKE_RATIO=2.5     # múltiplo del volumen promedio (SIT 7)
SCANNER_V2_GAP_PCT=2               # gap mínimo de apertura, solo acciones (SIT 10)

# --- Set v1: estrategias originales — true = activa | false = inactiva ---
SCANNER_RSI_SOBREVENTA=true        # alerta: RSI < umbral en 4H
SCANNER_RSI_SOBRECOMPRA=true       # alerta: RSI > umbral en 4H
SCANNER_EMA20_TOQUE=true           # alerta: precio dentro de ±dist% de la EMA20 en 1D
SCANNER_EMA20_RSI_SOBREVENTA=true  # señal LONG: EMA20 toque + RSI sobreventa + 1D/1W alcistas

# Umbrales del set v1
SCANNER_RSI_SOBREVENTA_UMBRAL=35   # RSI por debajo de este valor = sobreventa
SCANNER_RSI_SOBRECOMPRA_UMBRAL=70  # RSI por encima de este valor = sobrecompra
SCANNER_EMA20_DISTANCIA_PCT=1      # distancia máxima al EMA20 en % (ej. 2 = ±2%)
